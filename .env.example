# Copy to .env for local runs. Never commit .env.
# In CI, the same names are populated from GitHub Actions secrets.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Single-line JSON. Contents of credentials.json from Google Cloud (Desktop OAuth client).
GMAIL_CREDENTIALS={"installed":{"client_id":"...","client_secret":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}}

# Single-line JSON. Contents of token.json produced by the local OAuth flow.
GMAIL_TOKEN={"token":"...","refresh_token":"...","token_uri":"https://oauth2.googleapis.com/token","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.readonly"]}
